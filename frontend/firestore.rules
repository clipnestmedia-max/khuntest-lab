rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.role == "admin"
        && userDoc().data.isActive == true;
    }

    function isPatient() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.role == "patient"
        && userDoc().data.isActive == true;
    }

    function sameEmail(email) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.isActive == true
        && userDoc().data.email == email;
    }

    match /users/{uid} {
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role == "patient";
      allow create: if isAdmin();
      allow read, update: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow create: if isAdmin()
        || (
          request.resource.data.patientEmail is string
          && request.resource.data.patientName is string
          && request.resource.data.phone is string
        )
        || (
          isPatient()
          && request.resource.data.patientEmail == userDoc().data.email
          && request.resource.data.patientName is string
          && request.resource.data.phone is string
        );
      allow read: if isAdmin()
        || sameEmail(resource.data.patientEmail)
        || sameEmail(resource.data.email);
      allow update, delete: if isAdmin();
    }

    match /reports/{billNo} {
      allow read: if isAdmin()
        || (
          sameEmail(resource.data.patientEmail)
          && (resource.data.reportStatus == "Final" || resource.data.status == "Final")
        );
      allow create, update, delete: if isAdmin();
    }

    match /machineResults/{machineResultId} {
      allow read, write: if isAdmin();
    }

    match /tests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /packages/{packageId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // Temporary development-only rules, if needed during setup:
    // match /{document=**} {
    //   allow read, write: if true;
    // }
  }
}
