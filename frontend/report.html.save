<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Patient Report - KhunTest Lab</title>
  <style>
    body{font-family:Arial,sans-serif;background:#f5f8fc;margin:0;padding:20px;color:#071833}
    .page{max-width:900px;margin:auto;background:#fff;padding:34px;box-shadow:0 10px 35px rgba(0,0,0,.08)}
    .top{text-align:center;margin-bottom:20px}
    .top button{padding:10px 18px;font-weight:bold;cursor:pointer}
    .header{display:flex;gap:18px;align-items:center;border-bottom:3px solid #d60000;padding-bottom:14px;margin-bottom:20px}
    .header img{width:80px;height:80px;object-fit:contain}
    .header h1{color:#062b5f;margin:0;font-size:30px}
    .info{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:18px}
    .info div{border:1px solid #ddd;padding:9px;font-size:14px}
    table{width:100%;border-collapse:collapse;margin-top:15px}
    th{background:#062b5f;color:#fff;padding:10px;text-align:left;font-size:14px}
    td{border:1px solid #ccc;padding:9px;font-size:14px}
    .end{text-align:center;margin-top:30px;font-weight:bold}
    .error{max-width:650px;margin:80px auto;background:#fff;padding:30px;border-radius:16px;text-align:center;color:#991b1b}
    @media print{.top{display:none}body{background:#fff;padding:0}.page{box-shadow:none}}
  </style>
<style>
@page {
  size: A4;
  margin: 10mm 12mm;
}

body {
  background: #fff;
  font-family: Arial, Helvetica, sans-serif;
  font-size: 12px;
  color: #000;
  margin: 0;
  padding: 0;
}

.report-a4 {
  width: 190mm;
  min-height: 277mm;
  margin: 0 auto;
  background: #fff;
  padding: 6mm 4mm;
  box-sizing: border-box;
}

.report-top {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4px 24px;
  margin-top: 10px;
  margin-bottom: 14px;
}

.report-row {
  display: grid;
  grid-template-columns: 115px 10px 1fr;
  line-height: 1.45;
  font-size: 12px;
}

.report-row b {
  font-weight: 700;
}

.report-status {
  text-align: right;
  font-weight: 700;
}

.report-table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 12px;
  font-size: 12px;
}

.report-table th {
  text-align: left;
  border-bottom: 1px solid #000;
  padding: 5px 3px;
  font-weight: 700;
}

.report-table td {
  padding: 4px 3px;
  vertical-align: top;
}

.report-table .section-row td {
  padding-top: 8px;
  font-weight: 700;
}

.report-table .method-row td {
  font-size: 10px;
  padding-top: 0;
  color: #111;
}

.end-report {
  margin-top: 20px;
  text-align: center;
  font-weight: 700;
}

.no-print {
  text-align: center;
  margin: 12px;
}

@media print {
  .no-print,
  button,
  .header,
  .navbar,
  .sidebar {
    display: none !important;
  }

  body {
    background: #fff !important;
  }

  .report-a4 {
    width: auto;
    min-height: auto;
    margin: 0;
    padding: 0;
    box-shadow: none;
  }
}
</style>
</head>
<body>

<div class="top">
  <button onclick="window.print()">Print / Save PDF</button>
</div>

<div id="app">Loading report...</div>

<script>
function qs(name){return new URLSearchParams(location.search).get(name);}
function esc(v){return String(v||"").replace(/[&<>"']/g,m=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[m]));}
function dt(v){try{if(!v)return "";let d=new Date(v);return isNaN(d)?v:d.toLocaleString("en-IN");}catch{return v||"";}}

async function loadReport(){
  const bill = qs("bill");

  if(!bill){
    document.getElementById("app").innerHTML="<div class='error'>Bill number missing.</div>";
    return;
  }

  try{
    const res = await fetch("/api/reports/" + encodeURIComponent(bill));
    const data = await res.json();

    if(!data.success){
      document.getElementById("app").innerHTML="<div class='error'>"+esc(data.message||"Report not found")+"</div>";
      return;
    }

    const b = data.booking || {};
    const results = data.results || [];

    if(!results.length){
      document.getElementById("app").innerHTML="<div class='error'>Report is not released yet.</div>";
      return;
    }

    document.getElementById("app").innerHTML = `
      <div class="page">
        <div class="header">
          <img src="logo.png" onerror="this.style.display='none'">
          <div>
            <h1>KHUNTEST LAB</h1>
            <p><b style="color:#d60000;">Accurate • Reliable • Trusted</b></p>
            <p>Darbhanga, Bihar | +91 9234277007</p>
          </div>
        </div>

        <h2>Diagnostic Test Report</h2>

        <div class="info">
          <div><b>Bill No:</b> ${esc(b.bill_no)}</div>
          <div><b>Reporting Date:</b> ${esc(dt(b.reporting_date))}</div>
          <div><b>Patient Name:</b> ${esc(b.patient_name)}</div>
          <div><b>Age/Gender:</b> ${esc(b.patient_age)} / ${esc(b.patient_gender)}</div>
          <div><b>Contact:</b> ${esc(b.phone)}</div>
          <div><b>Email:</b> ${esc(b.email)}</div>
          <div><b>Ref. Doctor:</b> ${esc(b.ref_doctor)}</div>
          <div><b>Pathology:</b> ${esc(b.pathology_name || "BN-MAIN")}</div>
        </div>

        <table>
          <thead>
            <tr>
              <th>Test / Parameter</th>
              <th>Finding</th>
              <th>Unit</th>
              <th>Normal Value</th>
              <th>Comment</th>
            </tr>
          </thead>
          <tbody>
            ${results.map(r=>`
              <tr>
                <td>${esc(r.parameter_name || r.test_name)}</td>
                <td>${esc(r.finding)}</td>
                <td>${esc(r.unit)}</td>
                <td>${esc(r.normal_value)}</td>
                <td>${esc(r.comment)}</td>
              </tr>
            `).join("")}
          </tbody>
        </table>

        <div class="end">*** End of Report ***</div>
      </div>
    `;
  }catch(err){
    console.error(err);
    document.getElementById("app").innerHTML="<div class='error'>Server error while loading report.</div>";
  }
}

loadReport();
</script>
</body>
</html>
