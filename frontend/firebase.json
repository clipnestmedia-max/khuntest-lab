{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "backend/**",
      "database/**",
      "backups/**",
      "**/.env",
      "**/*.sql",
      "**/*.zip",
      "**/*.pdf"
    ],
    "headers": [
      {
        "source": "/listener-release.json",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, max-age=0, must-revalidate"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
